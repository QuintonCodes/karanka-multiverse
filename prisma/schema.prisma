generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum userRoles {
  user
  admin
}

enum paymentMethod {
  debitCard
  tokenPurchase
}

enum paymentStatus {
  pending
  confirmed
  failed
  expired
  refunded
}

enum paymentType {
  send
  receive
  purchase
  reward
}

enum productType {
  onceOff
  subscription
  unavailable
}

enum slugType {
  basic
  pro
  premium
}

enum subStatus {
  active
  cancelled
  expired
}

model User {
  id String @id @default(cuid())
  firstName String
  lastName String
  password String
  email String @unique
  role userRoles @default(user)
  avatarUrl String?
  isVerified Boolean
  address String?
  city String?
  postalCode String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLogin   DateTime?

  payments Payment[]
  transactions Transaction[]
  wallet Wallet?
  otpCodes OtpCode[]
  subscriptions Subscription[]
}

model OtpCode {
  id String @id @default(cuid())
  userId String
  email String
  code String @unique
  used Boolean @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Wallet {
  id String @id @default(cuid())
  userId String @unique
  balance Decimal @default(0) // in KRKUNI Tokens
  value Decimal @default(0) // In ZAR (Rands)
  address String @unique
  chain String @default("bsc")
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Product {
  id String @id @default(cuid())
  slug String @unique
  name String
  description String?
  price Decimal @default(0)
  zarPrice Decimal @default(0)
  image String?
  tokens Int
  productType productType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]
  subscriptions Subscription[]
}

model TokenPackage {
  id          String   @id @default(cuid())
  slug slugType @unique
  name        String
  description String?
  tokens Int
  price    Decimal
  zarPrice    Decimal
  features String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments Payment[]
}

model Payment {
  id String @id @default(cuid())
  userId String
  productId String?
  tokenPackageId String?
  amount Decimal @default(0)
  paymentMethod paymentMethod
  status paymentStatus @default(pending)
  transactionReference String? @unique
  paymentDate DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  transaction Transaction?
  subscription Subscription?
  product Product? @relation(fields: [productId], references: [id])
  tokenPackage TokenPackage? @relation(fields: [tokenPackageId], references: [id])
}

model Transaction {
  id String @id @default(cuid())
  userId String
  paymentId String? @unique
  from String
  to String
  amount Decimal @default(0)
  type paymentType
  status paymentStatus @default(pending)
  paymentMethod paymentMethod
  txHash String? @unique
  confirmed Boolean @default(false)
  gasUsed Int?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])
}

model Subscription {
  id String @id @default(cuid())
  userId String
  productId String
  paymentId String? @unique
  startsAt DateTime @default(now())
  endsAt DateTime
  cancelledAt DateTime?
  autoRenew Boolean @default(false)
  status subStatus @default(active)

  user User @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])
}