generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum userRoles {
  user
  admin
}

enum paymentMethod {
  debitCard
  eft
  creditCard
  tokenPurchase
  crypto
}

enum paymentStatus {
  pending
  confirmed
  failed
  expired
  refunded
}

enum paymentType {
  send
  receive
  purchase
  reward
}

enum productType {
  onceOff
  subscription
  tokenPackage
  unavailable
}

enum subStatus {
  active
  cancelled
  expired
}

model User {
  id         String    @id @default(cuid())
  firstName  String
  lastName   String
  password   String
  email      String    @unique
  role       userRoles @default(user)
  avatarUrl  String?
  isVerified Boolean
  address    String?
  city       String?
  postalCode String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastLogin  DateTime?

  payments      Payment[]
  transactions  Transaction[]
  wallet        Wallet?
  otpCodes      OtpCode[]
  subscriptions Subscription[]
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  email     String
  code      String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Wallet {
  id     String @id @default(cuid())
  userId String? @unique

  balance  Decimal @default(0) // KRKUNI Balance
  valueZar Decimal? // In ZAR (Rands)

  address    String   @unique
  chain      String?
  nonce String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Payment {
  id                   String         @id @default(cuid())
  userId               String
  productId            String?
  amount               Decimal        @default(0) // ZAR amount charged by PayFast
  paymentMethod        paymentMethod?
  status               paymentStatus  @default(pending)
  transactionReference String?        @unique
  paymentDate          DateTime       @default(now())

  productName   String
  productSlug   String
  productType   productType
  productTokens Decimal     @default(0)
  productPrice  Decimal     @default(0)

  user         User          @relation(fields: [userId], references: [id])
  transaction  Transaction?
  subscription Subscription?
  items        PaymentItem[]
}

model PaymentItem {
  id        String @id @default(cuid())
  paymentId String
  productId String
  quantity  Int    @default(1)

  payment Payment @relation(fields: [paymentId], references: [id])
}

model Transaction {
  id            String         @id @default(cuid())
  userId        String
  paymentId     String?        @unique
  from          String
  to            String
  amount        Decimal        @default(0) // In KRKUNI or ZAR
  type          paymentType
  status        paymentStatus  @default(pending)
  paymentMethod paymentMethod?
  txHash        String?        @unique
  confirmed     Boolean        @default(false)
  gasUsed       Int?
  timestamp     DateTime       @default(now())

  user    User     @relation(fields: [userId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])
}

model Subscription {
  id          String    @id @default(cuid())
  userId      String
  productId   String
  paymentId   String?   @unique
  amount      Decimal   @default(0) // ZAR amount charged by PayFast
  startsAt    DateTime  @default(now())
  endsAt      DateTime
  cancelledAt DateTime?
  autoRenew   Boolean   @default(false)
  status      subStatus @default(active)

  productName   String
  productSlug   String
  productType   productType
  productTokens Decimal     @default(0)
  productPrice  Decimal     @default(0)

  user    User     @relation(fields: [userId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])
}
